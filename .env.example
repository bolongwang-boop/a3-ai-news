# Get a free API key from https://newsapi.org/register
AINEWS_NEWSAPI_KEY=your_newsapi_key_here

# PostgreSQL connection (Cloud SQL via private IP in production)
# AINEWS_DATABASE_URL=postgresql+asyncpg://ainews:password@10.x.x.x/ai_news
AINEWS_DATABASE_URL=
AINEWS_ENABLE_PERSISTENCE=false
AINEWS_RETENTION_DAYS=30

# CLI: write JSON output to a file instead of stdout
# AINEWS_OUTPUT_FILE=/tmp/ai-news.json
