                  "value": "application/json"
                }
              ],
              "body": "{\n  \"sources\": [\n    {\n      \"name\": \"NewsAPI\",\n      \"available\": true\n    },\n    {\n      \"name\": \"Google News\",\n      \"available\": true\n    }\n  ],\n  \"database_enabled\": false,\n  \"database_stats\": null\n}"
            },
