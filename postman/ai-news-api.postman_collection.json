              "name": "Sources (DB disabled)",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/api/v1/news/sources",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "news", "sources"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
